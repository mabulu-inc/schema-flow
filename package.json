{
  "name": "@mabulu-inc/schema-flow",
  "version": "1.0.0",
  "description": "Declarative zero-downtime PostgreSQL migrations. Flows your schema from current state to desired state via YAML-driven table definitions and procedural pre/post scripts.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "schema-flow": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "audit:deps": "pnpm audit --prod",
    "pack:check": "pnpm pack --pack-destination /tmp/sf-pack-check && rm -f /tmp/sf-pack-check/*.tgz",
    "outdated:check": "pnpm outdated || true",
    "ci": "pnpm install --frozen-lockfile && pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test && pnpm run audit:deps",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:db": "./scripts/test-db-start.sh",
    "test:db:stop": "./scripts/test-db-stop.sh",
    "test:db:ensure": "./scripts/test-db-ensure.sh",
    "pretest": "pnpm run test:db:ensure && tsc",
    "posttest": "pnpm run test:db:stop",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "pg": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "postgres",
    "migration",
    "declarative",
    "zero-downtime",
    "schema",
    "yaml",
    "database"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mabulu-inc/schema-flow"
  }
}
